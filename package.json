{
  "name": "casparcg-launcher",
  "version": "2.0.0-0",
  "author": "Julian Waller <julian@superfly.tv>",
  "description": "Simple launcher for CasparCG",
  "license": "MIT",
  "main": "./src/main/index.js",
  "type": "module",
  "scripts": {
    "build": "yarn build:vite && electron-builder",
    "build:dir": "yarn build:vite && electron-builder --dir",
    "dev:vite": "node scripts/dev-vite.mjs",
    "build:vite": "vite build --config vite.renderer.config.js",
    "lint": "eslint --ext .js,.vue src",
    "lint:fix": "eslint --ext .js,.vue --fix src",
    "release": "standard-version"
  },
  "build": {
    "productName": "casparcg-launcher",
    "appId": "no.nrk.tv-automation-casparcg-launcher",
    "directories": {
      "output": "build"
    },
    "files": [
      "src/main/**/*",
      "dist/renderer/**/*"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "static/",
        "to": "static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": "portable"
    },
    "linux": {
      "icon": "build/icons",
      "target": "AppImage"
    }
  },
  "dependencies": {
    "bootstrap-vue": "^2.15.0",
    "conf": "^6.2.4",
    "deep-equal": "^2.0.3",
    "electron-log": "^4.2.0",
    "express": "^4.16.3",
    "jquery": "^3.3.1",
    "moment": "^2.22.2",
    "pretty-bytes": "5.6.0",
    "ps-tree": "^1.2.0",
    "serve-index": "^1.7.2",
    "smoothscroll-polyfill": "^0.4.3",
    "string-argv": "^0.3.1",
    "vue": "^2.7.0",
    "vue-chat-scroll": "^1.2.1",
    "vue-router": "^3.0.1",
    "vuex": "^3.0.1",
    "xtend": "^4.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue2": "^2.3.0",
    "electron": "40.6.0",
    "electron-builder": "^22.7.0",
    "electron-debug": "^3.1.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^7.1.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.1.3",
    "eslint-plugin-vue": "^7.0.0-alpha.5",
    "prettier": "^2.0.5",
    "sass-embedded": "^1.97.3",
    "standard-version": "^8.0.0",
    "vite": "^7.0.0",
    "vue-template-compiler": "^2.7.0"
  },
  "engines": {
    "node": "^24"
  },
  "packageManager": "yarn@4.12.0"
}
