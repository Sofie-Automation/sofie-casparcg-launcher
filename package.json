{
  "name": "casparcg-launcher",
  "version": "2.0.0-0",
  "author": "Julian Waller <julian@superfly.tv>",
  "description": "Simple launcher for CasparCG",
  "license": "MIT",
  "main": "./src/main/index.js",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "build": "yarn build:vite && electron-builder --publish never",
    "build:dir": "yarn build:vite && electron-builder --dir --publish never",
    "dev": "node scripts/dev-vite.mjs",
    "build:vite": "vite build --config vite.config.js",
    "lint:raw": "eslint",
    "lint": "run lint:raw .",
    "lint-fix": "run lint --fix",
    "license-validate": "sofie-licensecheck",
    "release": "sofie-version"
  },
  "build": {
    "productName": "casparcg-launcher",
    "appId": "no.nrk.tv-automation-casparcg-launcher",
    "directories": {
      "output": "build"
    },
    "files": [
      "src/main/**/*",
      "dist/renderer/**/*"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "static/",
        "to": "static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": "portable"
    },
    "linux": {
      "icon": "build/icons",
      "target": "AppImage"
    }
  },
  "prettier": "@sofie-automation/code-standard-preset/.prettierrc.json",
  "lint-staged": {
    "*.{css,json,md,scss}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "run lint:raw --fix"
    ]
  },
  "dependencies": {
    "bootstrap-vue": "^2.15.0",
    "conf": "^6.2.4",
    "deep-equal": "^2.0.3",
    "electron": "40.6.0",
    "electron-log": "^4.2.0",
    "escape-html": "^1.0.3",
    "express": "^4.16.3",
    "jquery": "^3.3.1",
    "pretty-bytes": "5.6.0",
    "ps-tree": "^1.2.0",
    "serve-index": "^1.7.2",
    "smoothscroll-polyfill": "^0.4.3",
    "string-argv": "^0.3.1",
    "vue": "^2.7.0",
    "vue-chat-scroll": "^1.2.1",
    "vue-router": "^3.0.1",
    "vuex": "^3.0.1",
    "xtend": "^4.0.1"
  },
  "devDependencies": {
    "@sofie-automation/code-standard-preset": "^3.2.1",
    "@vitejs/plugin-vue2": "^2.3.4",
    "chokidar": "^4.0.3",
    "electron-builder": "^26.8.1",
    "electron-debug": "^3.1.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-vue": "^7.0.0-alpha.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.97.3",
    "standard-version": "^8.0.0",
    "typescript": "~5.7.3",
    "vite": "^7.3.1",
    "vue-template-compiler": "^2.7.0"
  },
  "engines": {
    "node": "^24"
  },
  "packageManager": "yarn@4.12.0"
}
